# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Optional: faster slash-command sync for one Discord server
DISCORD_GUILD_ID=

# Default MVP database. For PostgreSQL use: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/mentor_bot.db

# Active game plugin. Built-in: ark_se
GAME_PLUGIN=ark_se

MENTOR_ROLE_NAME=Ментор
MODERATOR_ROLE_NAME=Модератор
ADMIN_ROLE_NAME=Администратор
SESSION_CATEGORY_NAME=Менторство
ARCHIVE_CATEGORY_NAME=Архив менторства
MENTOR_SESSION_DAYS=14
SECURITY_REMINDER_DAYS=3
REQUEST_TIMEOUT_HOURS=24

# low_staff is the default: auto-admit mentors into probation, then auto-promote after clean sessions.
# Use strict to require manual /admin_approve before matching.
STAFFING_MODE=low_staff
PROBATION_SESSIONS=3
PROBATION_MAX_NEWBIES=1

LOG_LEVEL=INFO
